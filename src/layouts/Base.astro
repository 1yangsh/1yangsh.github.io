---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import { profile } from '../data/profile';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="ko" data-theme="">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="author" content={profile.name} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content="summary" />

    <!-- 테마를 페인트 전에 확정해 깜빡임 방지 -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.dataset.theme = saved;
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      })();
    </script>
  </head>

  <body>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>

    <header class="nav">
      <div class="nav-inner">
        <a href="/" class="brand">
          <span class="brand-mark" aria-hidden="true"></span>
          <span>{profile.name}</span>
        </a>
        <nav aria-label="주요 메뉴">
          <ul class="nav-links">
            {
              isHome ? (
                <>
                  <li>
                    <a href="#about">About</a>
                  </li>
                  <li>
                    <a href="#work">Experience</a>
                  </li>
                  <li>
                    <a href="#projects">Projects</a>
                  </li>
                  <li>
                    <a href="#contact">Contact</a>
                  </li>
                </>
              ) : (
                <li>
                  <a href="/#projects">← All projects</a>
                </li>
              )
            }
          </ul>
        </nav>
        <ThemeToggle />
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="foot">
      <div class="wrap foot-inner">
        <span>© {new Date().getFullYear()} {profile.name}</span>
        <span class="foot-meta">Built with Astro · Deployed on GitHub Pages</span>
      </div>
    </footer>

    <script>
      // 스크롤 진입 시 페이드 — 모션 최소화 설정이면 건너뜀
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll<HTMLElement>('.reveal');
      if (reduced) {
        targets.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px' }
        );
        targets.forEach((el) => io.observe(el));
      }

      // 스크롤 위치에 따라 현재 섹션 메뉴를 강조 (홈에서만 앵커 링크가 존재)
      const navLinks = [...document.querySelectorAll<HTMLAnchorElement>('.nav-links a')].filter(
        (a) => a.getAttribute('href')?.startsWith('#')
      );

      if (navLinks.length) {
        const bySection = new Map(
          navLinks.map((a) => [a.getAttribute('href')!.slice(1), a] as const)
        );
        const ids = [...bySection.keys()];
        const lastId = ids[ids.length - 1];
        const visible = new Set<string>();

        const apply = () => {
          // 페이지 바닥 근처면 마지막 섹션이 감지 밴드에 못 들어와도 현재로 본다
          const nearBottom =
            window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;

          let current: string | null = null;
          if (nearBottom) {
            current = lastId;
          } else {
            for (const id of ids) {
              if (visible.has(id)) {
                current = id;
                break;
              }
            }
          }

          bySection.forEach((link, id) => {
            if (id === current) link.setAttribute('aria-current', 'true');
            else link.removeAttribute('aria-current');
          });
        };

        const spy = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) visible.add(entry.target.id);
              else visible.delete(entry.target.id);
            });
            apply();
          },
          { rootMargin: '-20% 0px -55% 0px' }
        );

        bySection.forEach((_, id) => {
          const section = document.getElementById(id);
          if (section) spy.observe(section);
        });

        window.addEventListener('scroll', apply, { passive: true });
      }
    </script>

    <style>
      /* 화면 위에 떠 있는 알약형 내비 */
      .nav {
        position: fixed;
        top: 1rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 50;
        max-width: calc(100% - 1.5rem);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        height: 3rem;
        padding: 0 0.45rem 0 1.15rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        /* 블러가 걸리지 않는 브라우저에서도 읽히도록 불투명도를 충분히 준다.
           빌드 미니파이어가 -webkit- 접두사를 임의로 떨어뜨리므로 블러에 의존하지 않는다. */
        background: color-mix(in srgb, var(--surface) 88%, transparent);
        -webkit-backdrop-filter: blur(14px) saturate(150%);
        backdrop-filter: blur(14px) saturate(150%);
        box-shadow: 0 6px 24px -12px rgb(0 0 0 / 0.35);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 650;
        letter-spacing: -0.01em;
        white-space: nowrap;
      }

      .brand-mark {
        width: 9px;
        height: 9px;
        border-radius: 2px;
        background: var(--accent);
      }

      .nav-links {
        display: flex;
        gap: 0.15rem;
        font-size: 0.875rem;
        color: var(--muted);
      }

      .nav-links a {
        display: block;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        transition:
          color 0.15s ease,
          background-color 0.15s ease;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .nav-links a[aria-current] {
        color: var(--accent);
        background: var(--accent-soft);
      }

      @media (max-width: 34rem) {
        .nav-links {
          display: none;
        }
      }

      .foot {
        border-top: 1px solid var(--border);
        padding-block: 2rem;
        font-size: 0.8125rem;
        color: var(--muted);
      }

      .foot-inner {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
        justify-content: space-between;
      }

      .foot-meta {
        font-family: var(--font-mono);
      }
    </style>
  </body>
</html>
