---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { profiles } from '../../../data/profile';
import { ui, projectsPath } from '../../../data/i18n';

const locale = 'en' as const;

export async function getStaticPaths() {
  const projects = (await getCollection('projectsEn')).sort((a, b) => a.data.order - b.data.order);

  return projects.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, next: projects[(i + 1) % projects.length] },
  }));
}

type Props = {
  entry: CollectionEntry<'projectsEn'>;
  next: CollectionEntry<'projectsEn'>;
};

const { entry, next } = Astro.props;
const { Content } = await render(entry);
const profile = profiles[locale];
---

<Base
  title={`${entry.data.title} · ${profile.nameEn}`}
  description={entry.data.summary}
  locale={locale}
>
  <article>
    <header class="head">
      <div class="wrap">
        <p class="meta">
          <span>{entry.data.org}</span>
          <span aria-hidden="true">·</span>
          <span>{entry.data.period}</span>
        </p>
        <h1>{entry.data.title}</h1>
        <p class="summary">{entry.data.summary}</p>
        {
          entry.data.role && (
            <p class="role">
              <span class="role-key">{ui.project.roleKey[locale]}</span>
              {entry.data.role}
            </p>
          )
        }
        <ul class="chips">
          {entry.data.stack.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </header>

    <div class="wrap prose">
      <Content />
    </div>
  </article>

  <nav class="next-nav" aria-label={ui.project.nextNavLabel[locale]}>
    <div class="wrap">
      <a href={projectsPath(locale, next.id)}>
        <span class="next-label">{ui.project.nextProject[locale]}</span>
        <span class="next-title">{next.data.title} →</span>
      </a>
    </div>
  </nav>
</Base>

<style>
  .head {
    padding-block: calc(var(--nav-h) + clamp(1.25rem, 5vw, 2.75rem)) 2.25rem;
    border-bottom: 1px solid var(--border);
  }

  .meta {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }

  h1 {
    margin-top: 0.75rem;
    font-size: clamp(1.7rem, 4.8vw, 2.5rem);
    line-height: 1.28;
    letter-spacing: -0.025em;
    max-width: 20ch;
  }

  .summary {
    margin-top: 0.85rem;
    max-width: 52ch;
    color: var(--muted);
  }

  .role {
    margin-top: 1.1rem;
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    font-size: 0.9rem;
    max-width: 52ch;
  }

  .role-key {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }

  .chips {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .chips li {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--surface-2);
    color: var(--muted);
  }

  .prose {
    padding-block: clamp(2.5rem, 7vw, 3.5rem) clamp(3rem, 8vw, 4.5rem);
    max-width: 44rem;
  }

  .prose :global(h2) {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 2.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .prose :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  .prose :global(p) {
    margin-top: 1rem;
    color: var(--text);
  }

  .prose :global(h2 + p) {
    margin-top: 1.1rem;
  }

  .prose :global(ul) {
    margin-top: 1.1rem;
    display: grid;
    gap: 0.55rem;
  }

  .prose :global(li) {
    position: relative;
    padding-left: 1.1rem;
  }

  .prose :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72em;
    width: 5px;
    height: 5px;
    border-radius: 1px;
    background: var(--accent);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.35em;
  }

  .next-nav {
    border-top: 1px solid var(--border);
  }

  .next-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-block: 2rem;
  }

  .next-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .next-title {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .next-nav a:hover .next-title {
    color: var(--accent);
  }
</style>
