---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import { profile, strengths, timeline, stack } from '../data/profile';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title={`${profile.name} · ${profile.role}`}
  description={`${profile.headline} — ${profile.summary}`}
>
  <Hero />

  <!-- 소개 ─────────────────────────────────────────────── -->
  <section class="section" id="about">
    <div class="wrap">
      <h2 class="section-label">About</h2>
      <ul class="cards reveal">
        {
          strengths.map((s, i) => (
            <li class="card">
              <span class="num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 경력 ─────────────────────────────────────────────── -->
  <section class="section" id="work">
    <div class="wrap">
      <h2 class="section-label">Experience</h2>
      <ol class="timeline reveal">
        {
          timeline.map((t) => (
            <li>
              <span class="period">{t.period}</span>
              <div class="entry">
                <h3>
                  {t.org} <span class="role">{t.role}</span>
                </h3>
                <p>{t.note}</p>
              </div>
            </li>
          ))
        }
      </ol>

      <div class="stack reveal">
        {
          stack.map((g) => (
            <div class="stack-row">
              <span class="stack-name">{g.group}</span>
              <ul class="chips">
                {g.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 프로젝트 ─────────────────────────────────────────── -->
  <section class="section" id="projects">
    <div class="wrap">
      <h2 class="section-label">Projects</h2>
      <ul class="projects">
        {
          projects.map((p) => (
            <li class="reveal">
              <a href={`/projects/${p.id}/`} class="proj">
                <div class="proj-head">
                  <h3>{p.data.title}</h3>
                  <span class="period">{p.data.period}</span>
                </div>
                <p>{p.data.summary}</p>
                <ul class="chips small">
                  {p.data.stack.slice(0, 4).map((s) => (
                    <li>{s}</li>
                  ))}
                </ul>
                <span class="more" aria-hidden="true">
                  자세히 →
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 연락 ─────────────────────────────────────────────── -->
  <section class="section contact" id="contact">
    <div class="wrap contact-wrap">
      <h2 class="contact-title reveal">
        이야기<span class="accent"> 나눠요</span>
      </h2>
      <p class="contact-lede reveal">
        데이터 엔지니어링, AI 인프라, 혹은 흥미로운 기술 문제와 기회에 대해<br />
        언제든 편하게 이야기 나누는 것을 환영합니다.
      </p>
      <ul class="contact-actions reveal">
        <li>
          <a
            href={`mailto:${profile.email}`}
            class="pill pill-primary"
            aria-label={`이메일 보내기 — ${profile.email}`}
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 6h16v12H4z M4 6l8 7 8-7"
              />
            </svg>
          </a>
        </li>
        <li>
          <a
            href={profile.linkedin}
            rel="me noopener"
            class="pill"
            aria-label="LinkedIn — yangseunghyeon"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M4.98 3.5a2.5 2.5 0 1 1 0 5.001 2.5 2.5 0 0 1 0-5zM3 9.75h4V21H3zM9.5 9.75H13v1.55h.05c.5-.93 1.7-1.9 3.5-1.9 3.75 0 4.45 2.45 4.45 5.65V21h-4V15.6c0-1.3-.03-3-1.85-3-1.85 0-2.15 1.45-2.15 2.9V21h-4z"
              />
            </svg>
          </a>
        </li>
        <li>
          <a href={profile.github} rel="me noopener" class="pill" aria-label="GitHub — 1yangsh">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.95 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03A9.56 9.56 0 0 1 12 6.8c.85 0 1.71.11 2.51.33 1.9-1.3 2.74-1.03 2.74-1.03.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.85-2.34 4.7-4.57 4.95.36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10 10 0 0 0 12 2z"
              />
            </svg>
          </a>
        </li>
      </ul>
      <p class="contact-email reveal">
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
      </p>
    </div>
  </section>
</Base>

<style>
  /* 소개 카드 */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.4rem;
  }

  .num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  .card h3 {
    font-size: 1.05rem;
    margin-top: 0.35rem;
    letter-spacing: -0.01em;
  }

  .card p {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  /* 경력 타임라인 */
  .timeline li {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.5rem;
    padding-block: 1.4rem;
    border-top: 1px solid var(--border);
  }

  .timeline li:last-child {
    border-bottom: 1px solid var(--border);
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    padding-top: 0.2rem;
  }

  .entry h3 {
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

  .role {
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--muted);
    margin-left: 0.4rem;
  }

  .entry p {
    margin-top: 0.3rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  @media (max-width: 40rem) {
    .timeline li {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }

  /* 기술 스택 */
  .stack {
    margin-top: 2.5rem;
    display: grid;
    gap: 0.9rem;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
  }

  .stack-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (max-width: 40rem) {
    .stack-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .chips li {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--surface-2);
    color: var(--muted);
  }

  /* 프로젝트 카드 */
  .projects {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1rem;
  }

  .proj {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .proj:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .proj-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
  }

  .proj h3 {
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

  .proj > p {
    margin-top: 0.55rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .chips.small {
    margin-top: 1rem;
  }

  .more {
    margin-top: auto;
    padding-top: 1.1rem;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--accent);
  }

  /* 연락 */
  .contact-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .contact-title {
    font-size: clamp(2.4rem, 6vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  .contact-title .accent {
    color: var(--accent);
  }

  .contact-lede {
    color: var(--muted);
    max-width: 44ch;
    font-size: 1rem;
    line-height: 1.7;
  }

  .contact-actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.5rem;
    height: 3rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--muted);
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background 0.18s ease,
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .pill:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .pill-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
    box-shadow: 0 8px 24px -8px var(--accent-soft);
  }

  .pill-primary:hover {
    color: var(--bg);
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -8px var(--accent-soft);
  }

  .contact-email {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .contact-email a:hover {
    color: var(--accent);
  }
</style>
